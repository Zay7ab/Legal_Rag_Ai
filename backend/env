# ─── RAG retrieval ────────────────────────────────────────────────────
# Embedding model. Multilingual by default because the app answers in Urdu
# and its users write Roman Urdu; the English-only model scored native Urdu
# queries at chance. Changing this REQUIRES rebuilding the index
# (python scripts/ingest_laws.py) — the app refuses to load an index built
# with a different model rather than return confident nonsense.
RAG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# L2 distance cutoff for "did we find a relevant statute?".
# Model- and corpus-specific — re-measure with scripts/eval_retrieval.py after
# changing either. Measured optimum for the default model: 1.05
# (keeps 16/17 real questions, admits 0/6 nonsense ones).
RAG_SIMILARITY_THRESHOLD=1.05
